# Docker Compose bind settings. Copy to .env; do not put secret values here.
GLACIER_HTTP_BIND=127.0.0.1
GLACIER_HTTP_PORT=8080
GLACIER_MANAGEMENT_BIND=127.0.0.1
GLACIER_MANAGEMENT_PORT=9000
GLACIER_PUBLIC_BASE_URL=http://localhost:8080
GLACIER_METRICS_ENABLED=true

# Full server backups are disabled unless explicitly enabled. Protect this directory externally.
GLACIER_BACKUP_ENABLED=false
GLACIER_BUILD_IDENTIFIER=local

# Immutable after the first image upload: FILESYSTEM, POSTGRESQL, or S3.
GLACIER_IMAGE_BACKEND=FILESYSTEM
GLACIER_S3_ENDPOINT=
GLACIER_S3_REGION=us-east-1
GLACIER_S3_BUCKET=glacier-notes
GLACIER_S3_PATH_STYLE=true
GLACIER_S3_ACCESS_KEY_FILE=
GLACIER_S3_SECRET_KEY_FILE=
GLACIER_S3_SERVER_SIDE_ENCRYPTION=
GLACIER_S3_API_CALL_TIMEOUT_SECONDS=30
GLACIER_S3_API_CALL_ATTEMPT_TIMEOUT_SECONDS=10

# Portable import/export staging limits and retention.
GLACIER_TRANSFER_MAXIMUM_UPLOAD_BYTES=1610612736
GLACIER_TRANSFER_MAXIMUM_DECODED_IMAGE_BYTES=1073741824
GLACIER_TRANSFER_RETENTION_HOURS=24
GLACIER_HTTP_DEFAULT_MAXIMUM_BODY_BYTES=10485760
GLACIER_HTTP_MULTIPART_OVERHEAD_BYTES=1048576
GLACIER_HTTP_ABSOLUTE_MAXIMUM_BODY_BYTES=1611661312

# Local-only ports used by compose.minio.yaml.
GLACIER_MINIO_API_PORT=9002
GLACIER_MINIO_CONSOLE_PORT=9003

# Paths to operator-managed secret files.
GLACIER_DATABASE_PASSWORD_FILE=./deployment/secrets/database-password.txt
GLACIER_BOOTSTRAP_TOKEN_FILE=./deployment/secrets/bootstrap-token.txt
GLACIER_SESSION_SECRET_FILE=./deployment/secrets/session-secret.txt

# Optional outbound SMTP. Mount GLACIER_SMTP_PASSWORD_FILE into the app container when used.
GLACIER_SMTP_ENABLED=false
GLACIER_SMTP_HOST=smtp.example.com
GLACIER_SMTP_PORT=587
GLACIER_SMTP_START_TLS=REQUIRED
GLACIER_SMTP_TLS=false
GLACIER_SMTP_USERNAME=
GLACIER_SMTP_PASSWORD_FILE=
GLACIER_SMTP_SENDER_NAME=Glacier Notes
GLACIER_SMTP_SENDER_ADDRESS=notes@example.com
