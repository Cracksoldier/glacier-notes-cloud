# Docker Compose bind settings. Copy to .env; do not put secret values here.
GLACIER_HTTP_BIND=127.0.0.1
GLACIER_HTTP_PORT=8080
GLACIER_MANAGEMENT_BIND=127.0.0.1
GLACIER_MANAGEMENT_PORT=9000
GLACIER_PUBLIC_BASE_URL=http://localhost:8080

# Paths to operator-managed secret files.
GLACIER_DATABASE_PASSWORD_FILE=./deployment/secrets/database-password.txt
GLACIER_BOOTSTRAP_TOKEN_FILE=./deployment/secrets/bootstrap-token.txt
GLACIER_SESSION_SECRET_FILE=./deployment/secrets/session-secret.txt
